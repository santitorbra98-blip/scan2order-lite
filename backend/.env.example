APP_NAME=Scan2Order
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com
FRONTEND_URL=https://your-domain.com
APP_HTTPS_PORT=443
HEALTH_CHECK_TOKEN=CHANGE_ME_STRONG_RANDOM

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=scan2order_lite
DB_USERNAME=scan2order
DB_PASSWORD=CHANGE_ME

FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
CACHE_STORE=file
SESSION_LIFETIME=120
SANCTUM_EXPIRATION=240

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=your-email@gmail.com
MAIL_FROM_NAME="${APP_NAME}"

MFA_EMAIL_CODE_TTL_MINUTES=10
MFA_EMAIL_MAX_ATTEMPTS=5

SECURITY_AUDIT_RETENTION_DAYS=90

SANCTUM_STATEFUL_DOMAINS=your-domain.com

CORS_ALLOWED_ORIGINS=https://your-domain.com

# Legal / Compliance — required for legal pages
LEGAL_COMPANY_NAME="Tu Razón Social S.L."
LEGAL_OWNER_TYPE=sociedad_limitada
LEGAL_TAX_ID=B00000000
LEGAL_ADDRESS="Calle Ejemplo, 1"
LEGAL_POSTAL_CODE=00000
LEGAL_CITY=Ciudad
LEGAL_PROVINCE=Provincia
LEGAL_COUNTRY=España
LEGAL_CONTACT_EMAIL=legal@your-domain.com
LEGAL_SUPPORT_EMAIL=soporte@your-domain.com
LEGAL_PRIVACY_EMAIL=privacidad@your-domain.com
LEGAL_SUPPORT_PHONE="+34 000 000 000"
LEGAL_REGISTRY_DATA="Registro Mercantil de ..., Tomo X, Folio Y"
LEGAL_JURISDICTION_CITY=Madrid
